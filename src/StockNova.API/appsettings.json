{
  "Database": {
    "Host": "localhost",
    "Port": 5432,
    "Name": "stocknova_db",
    "Username": "stocknova"
  },
  "JwtSettings": {
    "SecretKey": "OVERRIDE-IN-ENV-MUST-BE-AT-LEAST-32-CHARACTERS",
    "Issuer": "StockNova.API",
    "Audience": "StockNova.Client",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
