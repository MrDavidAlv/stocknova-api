# ============================================
# StockNova API - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to git
# ============================================

# PostgreSQL
POSTGRES_DB=stocknova_db
POSTGRES_USER=stocknova
POSTGRES_PASSWORD=your_secure_password_here

# API
ASPNETCORE_ENVIRONMENT=Production

# JWT
JWT_SECRET_KEY=your-secret-key-must-be-at-least-32-characters-long
JWT_ISSUER=StockNova.API
JWT_AUDIENCE=StockNova.Client
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7

# CORS (comma separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
